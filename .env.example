# =========================
# Database
# =========================
POSTGRES_USER=meam
POSTGRES_PASSWORD=meam_secret
POSTGRES_DB=meam_db
DATABASE_URL=postgresql://meam:meam_secret@db:5432/meam_db

# =========================
# Redis / Worker
# =========================
REDIS_URL=redis://redis:6379/0

# =========================
# Public URLs
# These values must be reachable from the browser.
# Locally you can keep localhost; for server deployment change to your IP or domain.
# =========================
API_PUBLIC_URL=http://localhost:3000/api
CANTALOUPE_PUBLIC_URL=http://localhost:8182/iiif/2

# =========================
# Moonshot / AI Assistant
# Moonshot (Kimi) uses an OpenAI-compatible Chat Completions API.
# =========================
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5
OPENAI_TIMEOUT_SECONDS=30

# Optional compatibility overrides if you want to point the same code at a
# different OpenAI-compatible provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# =========================
# File Paths
# HOST_MUSEUM_PATH is the host directory that will be mounted into /app/uploads.
# Local development can use ./uploads; production should point at NAS or a data disk.
# =========================
HOST_MUSEUM_PATH=./uploads
UPLOAD_DIR=/app/uploads

# =========================
# Image / Processing
# =========================
VIPS_DISC_THRESHOLD=100m
VIPS_CONCURRENCY=2
JAVA_OPTS=-Xmx4g -Djava.security.egd=file:/dev/./urandom

# =========================
# Ports
# =========================
FRONTEND_PORT=3000
BACKEND_PORT=8000
DB_PORT=5432
REDIS_PORT=6379
CANTALOUPE_PORT=8182
